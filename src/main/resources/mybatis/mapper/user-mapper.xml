<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.security.mapper.UserMapper">

    <select id="selectUserById" resultType="com.example.security.dto.UserDTO">
        SELECT * FROM user WHERE id = #{id}
    </select>

    <insert id="insertUser">
        INSERT INTO user (id, password, nickname, phone, email, register_date)
        VALUES (#{id}, #{password}, #{nickname}, #{phone}, #{email}, CURDATE())
    </insert>
</mapper>